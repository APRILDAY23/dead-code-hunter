{
  "name": "dead-code-hunter",
  "version": "1.0.13",
  "description": "Find and eliminate unused code across your entire project - JS/TS, Python, Go, Java, Ruby, Rust, PHP, C#",
  "bin": {
    "dch": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dead-code-hunter-core": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0"
  },
  "license": "MIT",
  "keywords": [
    "dead code",
    "unused code",
    "static analysis",
    "typescript",
    "javascript",
    "python",
    "go",
    "java",
    "rust",
    "ruby",
    "php",
    "csharp",
    "cli",
    "linter"
  ],
  "homepage": "https://github.com/APRILDAY23/dead-code-hunter",
  "repository": {
    "type": "git",
    "url": "https://github.com/APRILDAY23/dead-code-hunter.git"
  },
  "bugs": {
    "url": "https://github.com/APRILDAY23/dead-code-hunter/issues"
  },
  "author": "Veda Moola <vedamoola@gmail.com>"
}
